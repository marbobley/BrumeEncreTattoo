{
    "name": "marbobley/brume-encre-tattoo",
    "description": "Site de tattouage",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "phpdocumentor/reflection-docblock": "^6.0.1",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/asset": ">=8.0.6",
        "symfony/asset-mapper": ">=8.0.6",
        "symfony/console": ">=8.0.6",
        "symfony/dotenv": ">=8.0.6",
        "symfony/expression-language": ">=8.0.4",
        "symfony/flex": "^2.10",
        "symfony/form": ">=8.0.6",
        "symfony/framework-bundle": ">=8.0.6",
        "symfony/http-client": ">=8.0.6",
        "symfony/intl": ">=8.0.6",
        "symfony/mailer": ">=8.0.6",
        "symfony/mailtrap-mailer": ">=8",
        "symfony/messenger": "8.0.*",
        "symfony/mime": ">=8.0.6",
        "symfony/monolog-bundle": "^3.0|^4.0.1",
        "symfony/notifier": ">=8.0.6",
        "symfony/process": ">=8.0.5",
        "symfony/property-access": ">=8.0.4",
        "symfony/property-info": ">=8.0.6",
        "symfony/runtime": ">=8.0.1",
        "symfony/security-bundle": ">=8.0.6",
        "symfony/serializer": ">=8.0.6",
        "symfony/stimulus-bundle": "^2.32",
        "symfony/string": ">=8.0.6",
        "symfony/translation": ">=8.0.6",
        "symfony/twig-bundle": ">=8.0.4",
        "symfony/ux-leaflet-map": "^2.32",
        "symfony/ux-map": "^2.32",
        "symfony/ux-turbo": "^2.32",
        "symfony/validator": ">=8.0.6",
        "symfony/web-link": ">=8.0.4",
        "symfony/yaml": ">=8.0.6",
        "twig/extra-bundle": "^2.12|^3.23.0",
        "twig/twig": "^2.12|^3.23.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94.2",
        "phpstan/phpstan": "^2.1.40",
        "phpunit/phpunit": "^12.5.14",
        "symfony/browser-kit": ">=8.0.4",
        "symfony/css-selector": ">=8.0.6",
        "symfony/debug-bundle": ">=8",
        "symfony/maker-bundle": "^1.66.0",
        "symfony/phpunit-bridge": "^8.0.3",
        "symfony/stopwatch": ">=8",
        "symfony/web-profiler-bundle": ">=8.0.6"
    }
}
